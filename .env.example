# Akasha R2 (S3-compatible) — Cloudflare R2 bucket for mobile capture
# Create a bucket in Cloudflare R2 and generate an S3-compatible API token.
AKASHA_R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
AKASHA_R2_BUCKET=<bucket-name>
AKASHA_R2_ACCESS_KEY=<access-key-id>
AKASHA_R2_SECRET_KEY=<secret-access-key>

# Expo push notification token — get this from the mobile app after registering
# EXPO_PUSH_TOKEN=
